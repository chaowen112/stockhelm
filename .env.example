# Shioaji API Credentials
SHIOAJI_API_KEY=your_shioaji_api_key
SHIOAJI_SECRET_KEY=your_shioaji_secret_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWLIST=chat_id1,chat_id2

# Security
JWT_SECRET=your_jwt_secret_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stockhelm

# Admin User (Initial Setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password
